-- Listahan ng mga kailangang i-single harvest (PlantId lang)
local singleHarvestPlants = {
    ["Carrot"] = true,
    ["Tulip"] = true,
    ["Bamboo"] = true,
    ["Mushroom"] = true
}

-- GLOBAL STATES
local selectedHarvestPlants = {}
local autoHarvestEnabled = false

-- UPDATED BUFFER PACKET BUILDER
local function harvestPlantPacket(plantName, plantID, fruitID)
    local rawString
    
    -- Base sa bagong update: \177\000 ang header
    if singleHarvestPlants[plantName] or not fruitID then
        -- SINGLE HARVEST: $PlantId\000
        rawString = "\177\000$" .. tostring(plantID) .. "\000"
    else
        -- MULTI HARVEST: $PlantId$FruitId
        rawString = "\177\000$" .. tostring(plantID) .. "$" .. tostring(fruitID)
    end
    
    local myBuffer = buffer.fromstring(rawString)
    remoteEvent:FireServer(myBuffer)
end

-- UI COMPONENTS
Farm:Dropdown({
    Title = "Select Plants to Harvest",
    Desc = "Choose which plants to auto harvest",
    Values = allPlantsList,
    Multi = true,
    Default = {},
    AllowNone = true,
    Callback = function(selected)
        selectedHarvestPlants = selected or {}
    end
})

Farm:Toggle({
    Title = "Auto Harvest",
    Callback = function(state)
        autoHarvestEnabled = state
        if autoHarvestEnabled and gardensFolder then
            task.spawn(function()
                while autoHarvestEnabled do
                    for _, plot in pairs(gardensFolder:GetChildren()) do
                        if not autoHarvestEnabled then break end
                        
                        -- Tinitingnan ang "Plants" folder ng bawat plot
                        local plantsFolder = plot:FindFirstChild("Plants")
                        if plantsFolder then
                            for _, plantModel in pairs(plantsFolder:GetChildren()) do
                                if not autoHarvestEnabled then break end
                                
                                local fruitsFolder = plantModel:FindFirstChild("Fruits")
                                
                                -- 1. MULTI-HARVEST LOGIC (Strawberry, Tomato, etc.)
                                if fruitsFolder then
                                    for _, fruitModel in pairs(fruitsFolder:GetChildren()) do
                                        if not autoHarvestEnabled then break end
                                        
                                        -- Kinukuha ang data mula sa Attributes
                                        local ownerId = fruitModel:GetAttribute("UserId")
                                        local plantName = fruitModel:GetAttribute("CorePartName")
                                        local plantID = fruitModel:GetAttribute("PlantId")
                                        local fruitID = fruitModel:GetAttribute("FruitId")
                                        
                                        if ownerId == LocalPlayer.UserId and table.find(selectedHarvestPlants, plantName) then
                                            if plantID and fruitID then
                                                harvestPlantPacket(plantName, plantID, fruitID)
                                                task.wait(0.01)
                                            end
                                        end
                                    end
                                
                                -- 2. SINGLE-HARVEST LOGIC (Carrot, Bamboo, etc.)
                                else
                                    local ownerId = plantModel:GetAttribute("UserId")
                                    local plantName = plantModel:GetAttribute("SeedName") 
                                    local plantID = plantModel:GetAttribute("PlantId")
                                    local isReady = plantModel:GetAttribute("PlantGrowthReady") 
                                    
                                    if ownerId == LocalPlayer.UserId and isReady == true and table.find(selectedHarvestPlants, plantName) then
                                        if plantID then
                                            harvestPlantPacket(plantName, plantID, nil)
                                            task.wait(0.01)
                                        end
                                    end
                                end
                            end
                        end
                    end
                    task.wait(0.1)
                end -- Naitama na: Isinara ang habang loop
            end) -- Naitama na: Isinara ang task.spawn
        end
    end
})

