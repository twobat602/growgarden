-- TOGGLE: Ang Main Auto-Plant Loop
Farm:Toggle({
    Title = "Auto Plant Mode",
    Callback = function(state)
        autoPlantEnabled = state
        
        if autoPlantEnabled then
            task.spawn(function()
                while autoPlantEnabled do
                    local character = LocalPlayer.Character
                    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                    
                    if rootPart and humanoid then
                        for _, seedName in pairs(selectedPlantSeeds) do
                            if not autoPlantEnabled then break end
                            
                            local seedTool = LocalPlayer.Backpack:FindFirstChild(seedName) or character:FindFirstChild(seedName)
                            
                            if seedTool then
                                if seedTool.Parent == LocalPlayer.Backpack then
                                    humanoid:EquipTool(seedTool)
                                    task.wait(0.05)
                                end
                                
                                if not autoPlantEnabled then break end
                                
                                local playerPos = rootPart.Position
                                local targetY = getPlotYLevel() or (playerPos.Y - 3)
                                
                                local finalX = playerPos.X + (math.random(-5, 5) / 10)
                                local finalY = targetY
                                local finalZ = playerPos.Z + (math.random(-5, 5) / 10)
                                
                                local header = "\004\000"
                                local positionBytes = string.pack("fff", finalX, finalY, finalZ)
                                
                                local lengthIndicator = string.char(#seedName) 
                                local seedInfo = lengthIndicator .. seedName
                                
                                local rawPacket = header .. positionBytes .. seedInfo
                                local finalBuffer = buffer.fromstring(rawPacket)
                                
                                local args = {
                                    [1] = finalBuffer,
                                    [2] = { seedTool }
                                }
                                
                                remoteEvent:FireServer(unpack(args))
                                task.wait(0.01)
                            end
                        end
                    end
                    task.wait(0.05)
                end
            end)
        end
    end
})

