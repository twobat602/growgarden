local autoBuyEnabled = false

local Toggle = Shop:Toggle({
    Title = "Auto Buy Seed",
    Callback = function(state)
        autoBuyEnabled = state
        
        if autoBuyEnabled then
            -- Gumawa ng panibagong thread para hindi mag-freeze ang buong UI mo
